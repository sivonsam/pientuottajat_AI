AWS_REGION=eu-west-1
AWS_ACCOUNT_ID=

# WhatsApp Business Cloud API (Meta)
# Hae nämä osoitteesta: https://developers.facebook.com/apps/
WHATSAPP_TOKEN=          # Pysyvä access token Meta Business -tililtä
WHATSAPP_PHONE_NUMBER_ID= # Puhelinnumeron ID Meta-konsolista
WHATSAPP_VERIFY_TOKEN=   # Itse keksimäsi salainen merkkijono webhook-vahvistukseen

# Amazon Bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# DynamoDB
DYNAMODB_TABLE_SUPPLIERS=pientuottajat-suppliers
DYNAMODB_TABLE_CONVERSATIONS=pientuottajat-conversations

# SQS
SQS_NOTIFICATION_QUEUE_URL=

# True = mock-data, False = oikeat integraatiot
USE_MOCK_DATA=True

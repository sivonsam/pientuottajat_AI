        N8N["n8n\nWorkflow-automaatio\nBroadcast / hälytykset"]
        DASH["Dashboard\nRaportit & analytiikka"]
        SDATA["S-Data\nSnowflake\nmyynti & menekki"]
    end

    %% ══════════════════════════════════
    %% YHTEYDET
    %% ══════════════════════════════════
    S1 & S2 & S3 -->|"oma adapteri\n(toimittajan vastuulla)"| SAPI
    S4 -->|"WhatsApp-komento\ntai web-lomake"| SAPI

    SAPI -->|"validoitu data"| AICORE

    AICORE -->|"vastaus / proaktiivinen viesti"| CHANNELS
    CHANNELS -->|"toimittajan kysymys"| AICORE

    SDATA -->|"myynti & menekki\nper toimittaja"| MCP2
    N8N -->|"broadcast\nhälytys\nkysely"| CHANNELS
    AICORE -->|"hälytys\npoikkeama"| N8N
    AICORE -.->|"raporttidata"| DASH

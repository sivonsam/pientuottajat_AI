---
title: Pientuottajat AI — Tavoitearkkitehtuuri (Tuotanto)
---
flowchart TD

    subgraph SUPPLIERS["🧑‍🌾 TOIMITTAJAT"]
        direction LR
        S1["🌱 Tosipieni\nEi ERP · WhatsApp\nMaatila / käsityöläinen"]
        S2["🏭 Pieni\nNetvisor / Procountor\n1–5 henkilöä"]
        S3["🏢 Keskisuuri\nLemonsoft / Maestro\n5–50 henkilöä"]
    end

    subgraph CHANNELS["💬 KANAVAT  —  toimittaja valitsee mieluisimman"]
        direction LR
        WA["📱 WhatsApp\nBusiness API\n(Meta)"]
        TG["📱 Telegram\nBot API"]
        PORTAL["🌐 Web-portaali\nNext.js\nS3 + CloudFront"]
        SUPERSET["📊 Analytiikkaportaali\nApache Superset\nMyynti · Saatavuus\nHävikki · Ennuste\nAsiakasymmärrys"]
    end

    subgraph AUTH["🔐 TUNNISTAUTUMINEN  —  AWS Cognito"]
        direction LR
        COG["👤 Cognito User Pool\nSSO — yksi tunnus\nkaikkiin kanaviin\nsupplier_id JWT-tokenissa"]
        RLS["🔒 Row-Level Security\nToimittaja näkee\nvain oman datansa"]
        COG --> RLS
    end

    subgraph RESTAPI["📡 REST API  —  AWS API Gateway + Lambda"]
        direction LR
        GW["API Gateway\nHTTPS endpoint\n/v1/supplier/{id}/..."]
        INGEST["Ingest Lambda\nvalidointi &\nnormalisointi"]
        QUERY["Query Lambda\nmyynti · saatavuus\nhävikki · laskutus\nennuste · benchmark"]
        GW --> INGEST
        GW --> QUERY
    end

    subgraph STREAMAPI["⚡ STREAMING API  —  WebSocket + Kafka Consumer"]
        direction LR
        WSG["API Gateway\nWebSocket\nlivetapahtumat"]
        KCONS["Kafka Consumer\nLambda\nConfluent-topicit"]
        PROACT["Proactive Alert\nLambda\nEventBridge ajastimet"]
        KCONS -->|"saatavuus & reklamaatio\ntapahtumat"| WSG
        PROACT -->|"kynnysarvo-hälytykset"| WSG
    end

    subgraph AICORE["🧠 BEDROCK AGENT + MCP  —  Amazon Nova Pro"]
        direction TB
        AGENT["🤖 Bedrock Agent\nOrkestraattori\nText-to-SQL · Insight\nProaktiivinen analyysi"]
        subgraph MCP["⚙️ MCP Tool Layer"]
            direction LR
            T1["get_sales\nSnowflake"]
            T2["get_availability\nSnowflake·Kafka"]
            T3["get_reclamations\nDynamoDB"]
            T4["get_invoice\nSAP BTP"]
            T5["get_forecast\nSnowflake"]
            T6["get_benchmark\nSnowflake\n(kategoria-avg)"]
            T7["get_customer_insight\nSnowflake\npenetraatio·osto-\nkäyttäytyminen"]
            T8["send_alert\nWhatsApp·Telegram\nWebSocket"]
        end
        MEM["💾 DynamoDB\nmuisti · profiilit\nhälytysehdot"]
        AGENT --> MCP
        AGENT <--> MEM
    end

    subgraph DATASTORE["🗄️ VÄLIVARASTO  —  AWS"]
        direction LR
        DDB["💾 DynamoDB\ntoimitukset\nreklamaatiot\nkeskustelut"]
        SQS["📨 SQS\nviestijono"]
        EB["🕐 EventBridge\najastimet"]
    end

    subgraph SGROUP["🏪 S-RYHMÄ  —  OLEMASSA OLEVAT TAUSTAJÄRJESTELMÄT"]
        direction LR
        SNOW["❄️ Snowflake\nS-Data\nPolaris REST API\nMyynti · Saatavuus\nHävikki · Ennuste\nAsiakasymmärrys"]
        KAFKA["⚡ Confluent Kafka\nEvent streaming\nKassatapahtumat\nSaatavuusmuutokset"]
        SAP["🔷 SAP BTP\nKassadata\nOData API"]
    end

    %% Toimittajat → Kanavat
    S1 -->|"WhatsApp / Telegram"| WA & TG
    S2 -->|"WhatsApp · Web · Analytiikka"| WA & PORTAL & SUPERSET
    S3 -->|"Kaikki kanavat + API-avain"| WA & PORTAL & SUPERSET

    %% Kanavat → Auth
    WA & TG & PORTAL & SUPERSET --> AUTH

    %% Auth → API-kerrokset
    AUTH -->|"REST-kyselyt"| RESTAPI
    AUTH -->|"Live-tapahtumat"| STREAMAPI

    %% REST API → AI-ydin
    RESTAPI <-->|"AI-chat & insight"| AICORE

    %% Streaming → Kanavat (push-viestit)
    STREAMAPI -->|"push: hälytys · reklamaatio\nlive dashboard-päivitys"| WA & TG & PORTAL & SUPERSET

    %% AI-ydin → Tietovarasto
    AICORE <--> DATASTORE

    %% API & AI → Taustajärjestelmät
    RESTAPI <-->|"Polaris REST / SQL"| SNOW
    AICORE <-->|"MCP tools"| SNOW
    AICORE <-->|"OData"| SAP
    KAFKA -->|"Kafka Consumer"| KCONS
    KAFKA -->|"EventBridge Pipes"| EB
    EB --> PROACT
    SNOW <-->|"Secure Views\nRLS per supplier_id"| QUERY

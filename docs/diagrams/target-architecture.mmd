flowchart TB

    %% ══════════════════════════════════
    %% TOIMITTAJAT
    %% ══════════════════════════════════
    subgraph SUPPLIERS["🧑‍🌾 TOIMITTAJAT"]
        direction LR
        SA["Toimittaja A\n(Netvisor-adapteri)"]
        SB["Toimittaja B\n(Procountor-adapteri)"]
        SC["Toimittaja C\n(muu ERP-adapteri)"]
    end

    %% ══════════════════════════════════
    %% TOIMITTAJAN UI-KANAVAT
    %% ══════════════════════════════════
    subgraph CHANNELS["💬 TOIMITTAJAN KÄYTTÖLIITTYMÄT"]
        direction LR
        WA["📱 WhatsApp\nBusiness API\nkeskustelu & hälytykset"]
        TG["📱 Telegram\nBot API\nvaravkanava"]
        PORTAL["🌐 Toimittajaportaali\nNext.js / React\nS3 + CloudFront\n\nDashboard:\n• toimitukset\n• myynti & menekki\n• reklamaatiot\n• laskut\n• ennusteet"]
    end

    %% ══════════════════════════════════
    %% SUPPLIER API
    %% ══════════════════════════════════
    subgraph SAPI["📡 SUPPLIER API  (AWS API Gateway + Lambda)"]
        INGEST["Ingest Lambda\nvalidointi & normalisointi\n→ DynamoDB"]
        APIKEY["Cognito / API Key\nAuth per toimittaja"]
    end

    %% ══════════════════════════════════
    %% BEDROCK AGENT + MCP
    %% ══════════════════════════════════
    subgraph AICORE["🧠 BEDROCK AGENT + MCP  (AI-orkestraattori)"]
        direction TB

        AGENT["🤖 Bedrock Agent\nAmazon Nova Pro\n\nTehtävät:\n• ymmärtää toimittajan kysymyksen\n• valitsee oikeat MCP-työkalut\n• yhdistelee datan vastaukseksi\n• päättää proaktiivisista viesteistä\n• muistaa kontekstin"]

        subgraph MCP["⚙️ MCP TOOL LAYER  (Action Groups)"]
            direction LR
            T1["📦 get_deliveries\nhae toimitushistoria\n& poikkeamat"]
            T2["📊 get_sales_data\nkysy Snowflakesta\nmyynti per kauppa"]
            T3["🚨 get_reclamations\nhae & luo\nreklamaatiot"]
            T4["🏪 get_shelf_status\nhyllysaatavuus\n& puutteet"]
            T5["🧾 get_invoice_status\nlaskujen tila\n& maksut"]
            T6["📈 get_forecast\ntilausennuste\nper tuote & kauppa"]
            T7["📣 send_notification\nlähetä proaktiivinen\nviesti kanavaan"]
        end

        MEM["💾 DynamoDB\nkeskustelumuisti\ntoimittajaprofiili\npreferenssit\n(esim. 'hälytä hyllypuutteista')"]

        AGENT --> MCP
        AGENT <--> MEM
    end

    %% ══════════════════════════════════

title: Pientuottajat AI — Tavoitearkkitehtuuri (Tuotanto)
---
flowchart TB

    %% ══════════════════════════════════
    %% TOIMITTAJAT
    %% ══════════════════════════════════
    subgraph SUPPLIERS["🧑‍🌾 TOIMITTAJAT"]
        direction LR
        SA["Toimittaja A\n(Netvisor-adapteri)"]
        SB["Toimittaja B\n(Procountor-adapteri)"]
        SC["Toimittaja C\n(muu ERP -adapteri)"]
    end

    %% ══════════════════════════════════
    %% SUPPLIER API
    %% ══════════════════════════════════
    subgraph SAPI["📡 SUPPLIER API  (AWS API Gateway + Lambda)"]
        direction LR
        INGEST["Ingest Lambda\nvalidointi & normalisointi"]
        APIKEY["API Key Auth\nper toimittaja"]
    end

    %% ══════════════════════════════════
    %% S-RYHMÄ CORE SYSTEMS
    %% ══════════════════════════════════
    subgraph SGROUP["🏪 S-RYHMÄ — OLEMASSA OLEVAT JÄRJESTELMÄT"]
        direction LR
        SNOW["❄️ Snowflake\nS-Data\nmyynti / menekki\nhyllysaatavuus\ntilausennusteet"]
        KAFKA["⚡ Confluent Kafka\nEvent streaming\ntoimituspuutteet\nhyllypuutteet\nreklamaatiot"]
        SAP["🔷 SAP BTP\nKassadata\nTilaukset"]
    end

    %% ══════════════════════════════════
    %% AI YDIN
    %% ══════════════════════════════════
    subgraph AICORE["🧠 AI YDIN  (AWS Bedrock)"]
        direction TB
        AGENT["Bedrock Agent\nAmazon Nova Pro\norkestraatio"]
        subgraph MCP["MCP Tool Layer"]
            T1["Supplier data\n(DynamoDB)"]
            T2["S-Data query\n(Snowflake connector)"]
            T3["Event listener\n(Kafka consumer)"]
            T4["SAP BTP query\n(kassadata)"]
        end
        MEM["DynamoDB\nmuisti & profiilit"]
        AGENT --> MCP
        AGENT <--> MEM
    end

    %% ══════════════════════════════════
    %% PROAKTIIVISUUS
    %% ══════════════════════════════════
    subgraph PROACTIVE["⚡ PROAKTIIVISET HÄLYTYKSET  (Event-driven)"]
        EVB["EventBridge\nsäännöt & ajastimet"]
        ALERT["Alert Lambda\nhälytyslogiikka"]
        EVB --> ALERT
    end

    %% ══════════════════════════════════
    %% KANAVAT
    %% ══════════════════════════════════
    subgraph CHANNELS["💬 KANAVAT"]
        WA["WhatsApp\nBusiness API"]
        TG["Telegram\nBot API"]
    end

    %% ══════════════════════════════════
    %% YHTEYDET
    %% ══════════════════════════════════

    SA & SB & SC -->|"REST push\nAPI key"| SAPI
    SAPI -->|"normalisoitu data"| T1
    SAPI -->|"toimituseventti"| KAFKA

    SNOW <-->|"Snowflake connector\nData Sharing API"| T2
    KAFKA -->|"eventti-stream"| T3
    SAP -->|"OData / API"| T4

    CHANNELS -->|"toimittajan viesti"| AGENT
    AGENT -->|"vastaus"| CHANNELS

    KAFKA -->|"poikkeamaeventti"| EVB
    ALERT -->|"proaktiivinen\nWhatsApp / Telegram"| CHANNELS
    AGENT -->|"hälytys"| ALERT

    SNOW -->|"myynti & ennuste\nper toimittaja"| T2
